# Mission Control configuration
#
# Point this at the WebSocket URL of your OpenClaw gateway. Must be prefixed
# with NEXT_PUBLIC_ so it is exposed to the browser (Next.js convention).
# If unset, Mission Control falls back to ws://127.0.0.1:18789 (localhost).
#
# Examples:
#   NEXT_PUBLIC_OPENCLAW_WS_URL=ws://127.0.0.1:18789
#   NEXT_PUBLIC_OPENCLAW_WS_URL=ws://openclaw.local:18789
#   NEXT_PUBLIC_OPENCLAW_WS_URL=wss://openclaw.example.com/ws

NEXT_PUBLIC_OPENCLAW_WS_URL=ws://127.0.0.1:18789
